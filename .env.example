# ─── S3 Storage ───────────────────────────────────────────────────────
# AWS S3 credentials are required. Set S3_ENDPOINT only for non-AWS providers
# (Cloudflare R2, MinIO, DigitalOcean Spaces, etc.). When using AWS S3 directly,
# the SDK resolves the endpoint automatically — no S3_ENDPOINT needed.
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=agent-vault
# S3_ENDPOINT=https://your-r2-endpoint.com

# ─── Logging (optional) ─────────────────────────────────────────────
# Controls how verbose the server logs are. Defaults to "info" when unset.
#   debug — everything: S3 requests/responses, tool inputs, internal state
#   info  — normal operations: server started, plan saved/retrieved
#   warn  — only warnings like slow requests or recoverable errors
#   error — only failures
LOG_LEVEL=info

# ─── Transport: "stdio" (default) or "http" ─────────────────────────
TRANSPORT_MODE=stdio

# ─── HTTP Transport (only required when TRANSPORT_MODE=http) ─────────
# Bind address and port for the HTTP server
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
# Bearer token for API key authentication (required for HTTP mode)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or: openssl rand -hex 32
API_KEY=your-secret-api-key

# ─── CORS & Rate Limiting (optional, HTTP mode only) ────────────────
# Allowed CORS origins. Use "*" for any, or "https://yourapp.com" to restrict
CORS_ORIGIN=*
# Max requests per rate-limit window
RATE_LIMIT_MAX=100
# Rate-limit window in milliseconds
RATE_LIMIT_WINDOW=60000
